{
  "name": "super-nova-foundation",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "start": "node backend/start.js",
    "dev": "vite --host",
    "dev:server": "node backend/server.js",
    "dev:all": "concurrently -k -n VITE,SERVER -c cyan,green \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "serve": "npm run build && node backend/server.js",
    "backend:install": "cd backend && npm install",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
